# ---------------------------------------------------------------------------
# DIMS Admin Portal backend — environment template
# Copy to .env and fill in. .env is gitignored.
# Boot validates these via Zod (src/config/env.ts) and fails fast on missing values.
# ---------------------------------------------------------------------------

# --- App ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Comma-separated allowlist used by CORS middleware. No wildcards.
CORS_ORIGINS=http://localhost:3000

# --- Database (MS SQL Server, via Prisma) ---
# Prisma SQL Server URL format:
# sqlserver://HOST:PORT;database=DB;user=USER;password=PASS;encrypt=true;trustServerCertificate=true
DATABASE_URL=sqlserver://HOST:PORT;database=DB;user=USER;password=PASS;encrypt=true;trustServerCertificate=true

# --- Redis (DISABLED for single-server deploy) ---
# Optional. The Redis-backed stores are currently disabled: sessions live in
# the SQL Server DB, and rate-limit + permission caches are in-process. Leave
# unset to run without Redis. Set this (and re-enable the Redis backends in
# session/rateLimit/permissionsCache) when a Redis server is available.
# REDIS_URL=redis://localhost:6379

# --- Session ---
# Generate a strong random value, e.g. `openssl rand -base64 64`.
SESSION_SECRET=replace-me-with-a-long-random-string
SESSION_COOKIE_NAME=dims_admin_session
SESSION_COOKIE_TTL_HOURS=8

# --- Google OAuth ---
GOOGLE_CLIENT_ID=replace-me.apps.googleusercontent.com
GOOGLE_HOSTED_DOMAIN=exampledomain.com

# --- Service JWT (Express -> DIMS .NET) ---
# Dev defaults below. In prod, set ISSUER to your public origin (e.g.
# https://admin.datagainservices.com) and KEY_ID to a new identifier
# (e.g. prod-key-1) so prod and dev key ids never overlap.
SERVICE_JWT_ISSUER=http://localhost:4000
SERVICE_JWT_AUDIENCE=dims-api
SERVICE_JWT_TTL_SECONDS=180
# The kid embedded in the JWT header and exposed in JWKS. Bump on rotation.
SERVICE_JWT_KEY_ID=dev-key-1

# Where the RS256 keypair is loaded from: `file` (dev, from disk) or `aws`
# (prod, fetched from AWS Secrets Manager at boot via the task's IAM role).
SERVICE_JWT_KEY_SOURCE=file
# Required when SERVICE_JWT_KEY_SOURCE=file:
SERVICE_JWT_PRIVATE_KEY_PATH=./keys/private.pem
SERVICE_JWT_PUBLIC_KEY_PATH=./keys/public.pem
# Required when SERVICE_JWT_KEY_SOURCE=aws (do NOT set the *_PATH vars then).
# The secret holds JSON: {"privateKey":"<pem>","publicKey":"<pem>"}.
# SERVICE_JWT_KEY_SOURCE=aws
# SERVICE_JWT_KEYS_SECRET_ID=dims-admin/prod/jwt-keys
# AWS_REGION=us-east-1

# --- DIMS upstream ---
DIMS_API_BASE_URL=http://localhost:5000
DIMS_API_TIMEOUT_MS=10000

# --- Caches ---
PERMISSION_CACHE_TTL_SECONDS=300

# --- Feature flags (JSON object string) ---
FEATURES={}
